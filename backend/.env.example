# ===========================================================================
# AblePro Solutions — Backend environment variables (EXAMPLE)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# ===========================================================================

# --- Application -----------------------------------------------------------
APP_NAME="AblePro Solutions"
ENVIRONMENT=development            # development | staging | production | test
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- CORS (comma-separated origins) ----------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# --- Security / JWT --------------------------------------------------------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SECURE_COOKIES=false               # set true behind HTTPS in production
COOKIE_SAMESITE=lax

# --- Database (Supabase Postgres) ------------------------------------------
# Use the "Connection string" from Supabase > Project Settings > Database.
# Leave commented to use the local SQLite dev fallback. REQUIRED in production.
# DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Supabase (Auth + Storage) ---------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_STORAGE_BUCKET=audio-uploads

# --- Redis / Celery --------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Rate limiting ---------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=5/minute
RATE_LIMIT_ANONYMOUS=20/minute

# --- Uploads ---------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=100
ALLOWED_AUDIO_EXTENSIONS=wav,mp3,aac,ogg,m4a,flac

# --- ML models -------------------------------------------------------------
# Defaults resolve to <repo>/models/*.pkl — override only if relocated.
# ATYPICALITY_SCALER_PATH=
# ATYPICALITY_IFOREST_PATH=
# GENDER_AGE_MODEL_PATH=

# --- Whisper transcription -------------------------------------------------
WHISPER_MODEL_SIZE=small           # tiny|base|small|medium|large-v3
WHISPER_DEVICE=auto                # cpu|cuda|auto
WHISPER_COMPUTE_TYPE=int8
TRANSCRIPTION_SOURCE_LANGUAGE=kn
TRANSCRIPTION_TARGET_LANGUAGE=en

# --- Pyannote diarization --------------------------------------------------
# Accept the model terms on Hugging Face and create a token:
#   https://hf.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=hf_your_token_here
PYANNOTE_PIPELINE=pyannote/speaker-diarization-3.1
DIARIZATION_DEVICE=auto
# MIN_SPEAKERS=
# MAX_SPEAKERS=

# --- Audio -----------------------------------------------------------------
TARGET_SAMPLE_RATE=16000
ENABLE_NOISE_REDUCTION=true

# --- LLM gender/age fallback (optional, Google Gemini) ---------------------
# When the local gender/age model returns "unknown", the speaker's audio is
# sent to Gemini to estimate man / woman / child + age group. Leave the key
# blank to disable the fallback entirely.
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GENDER_AGE_LLM_FALLBACK=true
LLM_AUDIO_MAX_SECONDS=30

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO                     # DEBUG|INFO|WARNING|ERROR|CRITICAL
LOG_JSON=false
